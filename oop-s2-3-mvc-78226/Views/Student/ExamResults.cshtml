@model IEnumerable<oop_s2_3_mvc_78226.Models.ExamResult>

@{
    ViewData["Title"] = "My Exam Results";
}

<h2>My Exam Results</h2>

<table class="table">
    <thead>
        <tr>
            <th>Exam</th>
            <th>Score</th>
            <th>Max Score</th>
            <th>Grade</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var result in Model)
        {
            <tr>
                <td>@result.Exam.Title</td>
                <td>@result.Score</td>
                <td>@result.Exam.MaxScore</td>
                <td>@result.Grade</td>
            </tr>
        }
    </tbody>
</table>
