@model IEnumerable<oop_s2_3_mvc_78226.Models.FacultyCourseAssignment>

@{
    ViewData["Title"] = "My Courses";
}

<h2>My Courses</h2>

<table class="table">
    <thead>
        <tr>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var assignment in Model)
        {
            <tr>
                <td>@assignment.Course.Name</td>
                <td>
                    <a href="/Faculty/Students/@assignment.CourseId" class="btn btn-sm btn-primary">Students</a>
                    <a href="/Faculty/Gradebook/@assignment.CourseId" class="btn btn-sm btn-secondary">Gradebook</a>
                </td>
            </tr>
        }
    </tbody>
</table>