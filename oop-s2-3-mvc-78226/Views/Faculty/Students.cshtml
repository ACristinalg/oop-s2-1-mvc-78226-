@model IEnumerable<oop_s2_3_mvc_78226.Models.CourseEnrolment>

@{
    ViewData["Title"] = "My Students";
}

<h2>My Students</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var enrolment in Model)
        {
            <tr>
                <td>@enrolment.StudentProfile.Name</td>
                <td>@enrolment.StudentProfile.Email</td>
                <td>@enrolment.StudentProfile.Phone</td>
                <td>@enrolment.Status</td>
            </tr>
        }
    </tbody>
</table>
