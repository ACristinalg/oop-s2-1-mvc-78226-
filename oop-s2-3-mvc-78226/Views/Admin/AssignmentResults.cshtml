@model IEnumerable<oop_s2_3_mvc_78226.Models.AssignmentResult>

@{
    ViewData["Title"] = "Gradebook";
}

<h2>Gradebook</h2>

<a href="/Admin/CreateAssignmentResult" class="btn btn-primary mb-3">Add Result</a>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Assignment</th>
            <th>Score</th>
            <th>Max Score</th>
            <th>Feedback</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var result in Model)
        {
            <tr>
                <td>@result.StudentProfile.Name</td>
                <td>@result.Assignment.Title</td>
                <td>@result.Score</td>
                <td>@result.Assignment.MaxScore</td>
                <td>@result.Feedback</td>
            </tr>
        }
    </tbody>
</table>