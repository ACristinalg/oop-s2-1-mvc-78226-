@model IEnumerable<oop_s2_3_mvc_78226.Models.CourseEnrolment>

@{
    ViewData["Title"] = "Enrolments";
}

<h2>Enrolments</h2>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Enrol Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var enrolment in Model)
        {
            <tr>
                <td>@enrolment.StudentProfile.Name</td>
                <td>@enrolment.Course.Name</td>
                <td>@enrolment.EnrolDate.ToShortDateString()</td>
                <td>@enrolment.Status</td>
            </tr>
        }
    </tbody>
</table>
