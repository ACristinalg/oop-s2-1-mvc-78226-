@model oop_s2_3_mvc_78226.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<h2>Create Course</h2>

<form asp-action="CreateCourse" method="post">
    <div class="mb-3">
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Branch</label>
        <select asp-for="BranchId" class="form-control">
            @foreach (var b in ViewBag.Branches)
            {
                <option value="@b.Id">@b.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label>End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a href="/Admin/Courses" class="btn btn-secondary">Cancel</a>
</form>
