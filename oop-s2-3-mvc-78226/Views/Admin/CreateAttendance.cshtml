@model oop_s2_3_mvc_78226.Models.AttendanceRecord

@{
    ViewData["Title"] = "Add Attendance";
}

<h2>Add Attendance</h2>

<form asp-action="CreateAttendance" method="post">
    <div class="mb-3">
        <label>Enrolment</label>
        <select asp-for="CourseEnrolmentId" class="form-control">
            @foreach (var e in ViewBag.Enrolments)
            {
                <option value="@e.Id">@e.StudentProfile.Name - @e.Course.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Week Number</label>
        <input asp-for="WeekNumber" type="number" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Date</label>
        <input asp-for="Date" type="date" class="form-control" />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Present" type="checkbox" class="form-check-input" />
        <label class="form-check-label">Present</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Admin/Attendance" class="btn btn-secondary">Cancel</a>
</form>