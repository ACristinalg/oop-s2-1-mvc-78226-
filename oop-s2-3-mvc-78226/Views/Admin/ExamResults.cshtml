@model IEnumerable<oop_s2_3_mvc_78226.Models.ExamResult>

@{
    ViewData["Title"] = "Exam Results";
}

<h2>Exam Results</h2>

<a href="/Admin/CreateExamResult" class="btn btn-primary mb-3">Add Exam Result</a>

<table class="table">
    <thead>
        <tr>
            <th>Student</th>
            <th>Exam</th>
            <th>Score</th>
            <th>Max Score</th>
            <th>Grade</th>
            <th>Released</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var result in Model)
        {
            <tr>
                <td>@result.StudentProfile.Name</td>
                <td>@result.Exam.Title</td>
                <td>@result.Score</td>
                <td>@result.Exam.MaxScore</td>
                <td>@result.Grade</td>
                <td>@(result.Exam.ResultsReleased ? "Yes" : "No")</td>
            </tr>
        }
    </tbody>
</table>